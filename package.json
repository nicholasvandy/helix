{
  "name": "helix-monorepo",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/mcp",
    "packages/api",
    "dashboard"
  ],
  "scripts": {
    "build": "npm run build -w packages/core",
    "build:mcp": "npm run build -w packages/mcp",
    "test": "npm run test -w packages/core",
    "demo": "tsx examples/demo-all/run.ts",
    "demo:tempo": "tsx examples/demo-tempo/run.ts",
    "demo:privy": "tsx examples/demo-privy/run.ts",
    "demo:real": "tsx examples/real-http/run.ts",
    "demo:chain": "tsx examples/real-chain/run.ts",
    "dash": "tsx dashboard/server.ts",
    "mcp": "tsx packages/mcp/src/server.ts",
    "api": "tsx packages/api/src/server.ts",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
